@page "/map"
@rendermode InteractiveServer
@using MeshcomWebDesk.Models
@using MeshcomWebDesk.Services
@using Microsoft.Extensions.Options
@inject ChatService ChatService
@inject MeshcomUdpService UdpService
@inject LanguageService Loc
@inject IOptionsMonitor<MeshcomSettings> SettingsMonitor
@inject IJSRuntime JS
@inject QrzService QrzService
@inject ILogger<Map> Logger
@implements IDisposable

<PageTitle>🗺️ @Loc.T("Karte", "Map", "Mappa", "Mapa") – MeshCom WebDesk</PageTitle>

<div class="map-page">
    <div class="map-controls-bar">
        <button class="map-ctrl-btn" @onclick='() => JS.InvokeVoidAsync("meshcomMap.fitAll")'>
            📡 @Loc.T("Alle", "All", "Tutti", "Todos")
        </button>
        <button class="map-ctrl-btn" @onclick='() => JS.InvokeVoidAsync("meshcomMap.fitEurope")'>
            🌍 @Loc.T("Europa", "Europe", "Europa", "Europa")
        </button>
        <button class="map-ctrl-btn" @onclick="FitOwnAsync"
                disabled="@(!UdpService.Status.OwnLatitude.HasValue)"
                title="@Loc.T("50 km Radius um eigene Position", "50 km radius around own position", "50 km raggio intorno alla propria posizione", "Radio de 50 km alrededor de la propia posición")">
            📍 50 km
        </button>
    </div>
    <div id="meshcom-map" class="map-container"></div>

    @if (!_hasPositions)
    {
        <div class="map-no-data">
            📡 @Loc.T("Noch keine GPS-Positionen empfangen.", "No GPS positions received yet.",
                       "Nessuna posizione GPS ricevuta.", "Aún no se han recibido posiciones GPS.")
        </div>
    }

    @{
        var withGps = ChatService.MhList.Where(s => s.Latitude.HasValue).ToList();
        var ownStatus = UdpService.Status;
    }
    @if (withGps.Count > 0 || ownStatus.OwnLatitude.HasValue)
    {
        <div class="map-info-bar">
            <span>📡 @withGps.Count @Loc.T("Station(en) auf der Karte", "station(s) on map", "stazione/i sulla mappa", "estación/es en el mapa")</span>
            @if (ownStatus.OwnLatitude.HasValue)
            {
                <span class="map-info-sep"> · </span>
                <span>📍 @SettingsMonitor.CurrentValue.MyCallsign</span>
            }
        </div>
    }
</div>

@code {
    private bool _hasPositions;
    private bool _mapInitialized;
    private bool _disposed;

    protected override void OnInitialized()
    {
        Loc.OnChange            += StateHasChanged;
        ChatService.OnChange    += OnDataChanged;
        UdpService.OnStatusChange += OnDataChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await InitMapAsync();
        else if (_mapInitialized)
            await UpdateMarkersAsync();
    }

    private async void OnDataChanged()
    {
        if (_disposed) return;
        try
        {
            await InvokeAsync(async () =>
            {
                if (_disposed) return;
                if (_mapInitialized)
                    await UpdateMarkersAsync();
                StateHasChanged();
            });
        }
        catch (Exception) { }
    }

    private async Task InitMapAsync()
    {
        for (var attempt = 1; attempt <= 3; attempt++)
        {
            try
            {
                var status = UdpService.Status;
                await JS.InvokeVoidAsync("meshcomMap.init", "meshcom-map",
                    status.OwnLatitude.HasValue  ? (object)status.OwnLatitude.Value  : null,
                    status.OwnLongitude.HasValue ? (object)status.OwnLongitude.Value : null);
                _mapInitialized = true;
                await UpdateMarkersAsync();
                StateHasChanged();
                return;
            }
            catch (Exception ex) when (attempt < 3 && !_disposed)
            {
                Logger.LogWarning("Map init attempt {Attempt} failed: {Message} – retrying in 500 ms", attempt, ex.Message);
                await Task.Delay(500);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Map init failed after 3 attempts");
            }
        }
    }

    private async Task UpdateMarkersAsync()
    {
        var qrzEnabled = SettingsMonitor.CurrentValue.Qrz.Enabled;
        var stations = ChatService.MhList
            .Where(s => s.Latitude.HasValue && s.Longitude.HasValue)
            .Select(s =>
            {
                var qrz = qrzEnabled ? QrzService.GetCached(s.Callsign) : null;
                return new
                {
                    callsign = s.Callsign,
                    lat      = s.Latitude!.Value,
                    lon      = s.Longitude!.Value,
                    alt      = s.Altitude,
                    rssi     = s.LastRssi,
                    text     = s.LastMessage,
                    battery  = s.Battery,
                    qrzName  = qrz?.FirstName,
                    qrzLoc   = qrz?.Location
                };
            })
            .ToArray();

        var status   = UdpService.Status;
        _hasPositions = stations.Length > 0 || status.OwnLatitude.HasValue;

        await JS.InvokeVoidAsync("meshcomMap.updateMarkers",
            stations,
            SettingsMonitor.CurrentValue.MyCallsign,
            status.OwnLatitude,
            status.OwnLongitude);
    }

    private static string RssiCss(int rssi) =>
        rssi > -90 ? "rssi-good" : rssi > -105 ? "rssi-ok" : "rssi-weak";

    private async Task FitOwnAsync()
    {
        try
        {
            var status = UdpService.Status;
            if (status.OwnLatitude.HasValue && status.OwnLongitude.HasValue)
                await JS.InvokeVoidAsync("meshcomMap.fitOwn",
                    status.OwnLatitude.Value, status.OwnLongitude.Value, 50);
        }
        catch (Exception) { }
    }

    public void Dispose()
    {
        _disposed = true;
        Loc.OnChange              -= StateHasChanged;
        ChatService.OnChange      -= OnDataChanged;
        UdpService.OnStatusChange -= OnDataChanged;
    }
}
