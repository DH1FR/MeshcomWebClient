@page "/clear"
@rendermode InteractiveServer
@inject ChatService ChatService
@inject DataPersistenceService PersistenceService

<PageTitle>Daten löschen – MeshCom Web Client</PageTitle>

<div class="about-page">
    <div class="about-card clear-card">
        <div class="about-icon">🗑️</div>
        <h1 class="about-title">Daten löschen</h1>

        <div class="about-divider"></div>

        @if (_done)
        {
            <p class="clear-success">✅ Alle Daten wurden gelöscht.</p>
            <p class="clear-hint">Die Datei auf der Disk wurde ebenfalls geleert.</p>
        }
        else if (_confirm)
        {
            <p class="clear-warning">
                ⚠️ Alle Chat-Nachrichten, Monitor-Einträge und die MH-Liste werden
                <strong>unwiderruflich</strong> gelöscht. Fortfahren?
            </p>
            <div class="clear-buttons">
                <button class="btn-danger" @onclick="ExecuteClear">Ja, alles löschen</button>
                <button class="btn-cancel" @onclick="() => _confirm = false">Abbrechen</button>
            </div>
        }
        else
        {
            <p class="about-description">
                Löscht alle gespeicherten Daten:<br />
                Chat-Tabs &amp; Nachrichten · MH-Liste · Monitor-Feed
            </p>
            <div class="clear-buttons">
                <button class="btn-danger" @onclick="() => _confirm = true">Alle Daten löschen …</button>
            </div>
        }
    </div>
</div>

@code {
    private bool _confirm;
    private bool _done;

    private async Task ExecuteClear()
    {
        ChatService.ClearAllData();
        await PersistenceService.SaveAsync();
        _confirm = false;
        _done    = true;
    }
}
